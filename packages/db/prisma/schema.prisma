generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  status         String    @default("draft") // draft, awaiting_clarification, planning, etc.
  source         String    // web, whatsapp, imported
  repoUrl        String?
  workspacePath  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  threads        ProjectThread[]
  sessions       Session[]
  runs           Run[]
  approvals      Approval[]
  workspaces     Workspace[]
  fileIndices    FileIndex[]
  editPlans      EditPlan[]
}

model ProjectThread {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  role      String   // user, assistant, system
  content   String
  createdAt DateTime @default(now())
}

model Run {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id])
  currentStage   String    // planning, coding, reviewing...
  failureReason  String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  steps          RunStep[]
  editPlans      EditPlan[]
}

model RunStep {
  id        String   @id @default(cuid())
  runId     String
  run       Run      @relation(fields: [runId], references: [id])
  name      String   // classification, planning, coding_batch_1...
  status    String   // pending, active, completed, failed
  startedAt DateTime @default(now())
  endedAt   DateTime?
}

model Approval {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  summary     String
  riskLevel   String    // low, medium, high
  payload     Json?
  channel     String    // web, whatsapp
  status      String    @default("pending") // pending, approved, rejected
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
}

model Workspace {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  localPath   String
  gitBranch   String
  repoMode    String   // new, existing
  lockState   String   @default("unlocked")
  updatedAt   DateTime @updatedAt
}

model Session {
  id             String          @id @default(cuid())
  projectId      String
  project        Project         @relation(fields: [projectId], references: [id])
  title          String?
  source         String          @default("web") // web, whatsapp
  status         String          @default("idle") // idle, running, error
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  messages       SessionMessage[]
}

model SessionMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user, assistant, system
  content   String
  createdAt DateTime @default(now())
}

model FileIndex {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  filePath      String
  hash          String
  language      String
  symbols       Json
  imports       Json
  exports       Json
  lastIndexedAt DateTime @default(now())
}

model PromptUsage {
  id               String   @id @default(cuid())
  provider         String
  model            String
  promptTokens     Int
  cachedTokens     Int
  completionTokens Int
  stepId           String?
  createdAt        DateTime @default(now())
}

model WhatsappAccount {
  id              String   @id @default(cuid())
  operatorPhone   String   @unique
  sessionId       String?
  connectionState String   @default("disconnected")
  updatedAt       DateTime @updatedAt
}

model Notification {
  id             String   @id @default(cuid())
  channel        String   // web, whatsapp
  type           String   // approval, status, failure
  message        String
  deliveryStatus String   @default("pending") // pending, delivered, failed
  createdAt      DateTime @default(now())
}

model EditPlan {
  id          String     @id @default(cuid())
  projectId   String
  runId       String     @unique
  originalReq String
  status      String     @default("pending") // pending, executing, completed, failed
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tasks       EditTask[]
  project     Project    @relation(fields: [projectId], references: [id])
  run         Run        @relation(fields: [runId], references: [id])
}

model EditTask {
  id        String   @id @default(cuid())
  planId    String
  filePath  String
  intent    String
  isNewFile Boolean  @default(false)
  status    String   @default("pending") // pending, in_progress, completed, failed
  attempts  Int      @default(0)
  errorLog  String?

  plan      EditPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}
