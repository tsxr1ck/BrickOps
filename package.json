{
  "name": "brickops-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" run dev",
    "dev:api": "bun run apps/api/src/index.ts",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:whatsapp": "bun run apps/whatsapp-gateway/src/index.ts",
    "start": "bash start.sh",
    "agent": "bun run scripts/agent-cli.ts",
    "agent:single": "bun run scripts/agent-cli.ts --single",
    "build": "bun --filter \"*\" run build",
    "lint": "bun --filter \"*\" run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "puppeteer": "^24.43.1",
    "sharp": "^0.34.5"
  }
}
