{
  "name": "brickops-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter \"*\" run dev",
    "build": "bun --filter \"*\" run build",
    "lint": "bun --filter \"*\" run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "puppeteer": "^24.43.1"
  }
}
